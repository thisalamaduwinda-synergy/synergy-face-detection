# ── Database ────────────────────────────────────────────────
DB_TYPE=sqlite
SQLITE_PATH=data/employees.db

# PostgreSQL (used when DB_TYPE=postgresql)
PG_HOST=localhost
PG_PORT=5432
PG_NAME=face_recognition
PG_USER=postgres
PG_PASSWORD=your_secure_password_here

# ── Redis (optional) ────────────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── API Server ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_to_a_random_secret_key_in_production

# ── Dashboard ───────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# ── Face Recognition ────────────────────────────────────────
RECOGNITION_THRESHOLD=0.45
USE_GPU=false

# ── Alerts ──────────────────────────────────────────────────
ALERT_WEBHOOK_URL=

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
